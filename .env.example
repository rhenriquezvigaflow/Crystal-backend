DATABASE_URL=postgresql+psycopg2://postgres:replace-me@localhost:5432/crystal_plc
APP_ENV=development
LOG_LEVEL=INFO
PROXY_HEADERS_ENABLED=true
PROXY_TRUSTED_HOSTS=127.0.0.1,::1,localhost
CORS_ALLOWED_ORIGINS=http://127.0.0.1,http://localhost,https://127.0.0.1,https://localhost,http://localhost:3000,http://localhost:5173,http://localhost:5174,http://localhost:8085,https://localhost:5173,https://localhost:5174
WS_ALLOWED_ORIGINS=
WS_ALLOW_QUERY_TOKEN=false
COLLECTOR_API_KEY=replace-with-a-random-collector-key-of-at-least-24-chars
JWT_SECRET_KEY=replace-with-a-random-jwt-secret-of-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_ISSUER=crystal-scada
JWT_AUDIENCE=
SECURITY_ENFORCE_STRONG_SECRETS=false
SCADA_WATCHDOG_TIMEOUT_SEC=120
SCADA_WATCHDOG_RECOVERY_COOLDOWN_SEC=90
SCADA_WATCHDOG_CHECK_INTERVAL_SEC=20
SCADA_WATCHDOG_ENABLED=true
SCADA_WATCHDOG_HARD_RESTART=false
SCADA_WATCHDOG_STARTUP_GRACE_SEC=60
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_PORT=587
MAIL_SERVER=smtp-mail.outlook.com
MAIL_STARTTLS=true
MAIL_SSL_TLS=false
